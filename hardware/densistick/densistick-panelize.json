// KiKit panelization for the Printalizer DensiStick
// This produces a 187.5x135.0mm sized panel, containing 10 boards.
// Edge rails are on all sides, and tooling holes are designed for 1.5mm pins.
{
    "layout": {
        "type": "grid",
        "rows": 5,
        "cols": 2,
        "hspace": "2.5mm",
        "vspace": "2.5mm",
        "renamenet": "Board_{n}-{orig}",
        "renameref": "{orig}"
    },
    "source": {
        "type": "auto",
        "tolerance": "5mm"
    },
    "tabs": {
        "type": "annotation"
    },
    "cuts": {
        "type": "mousebites",
        "drill": "0.5mm",
        "spacing": "0.7mm"
    },
    "framing": {
        "type": "frame",
        "width": "5mm",
        "space": "2.5mm",
        "cuts": "h"
    },
    "tooling": {
        "type": "4hole",
        "hoffset": "4.75mm",
        "voffset": "2.5mm",
        "size": "1.55mm",
        "soldermaskmargin": "0.15mm"
    },
    "fiducials": {
        "type": "3fid",
        "hoffset": "10mm",
        "voffset": "2.5mm",
        "coppersize": "1mm",
        "opening": "2mm"
    },
    "text": {
        "type": "simple",
        "text": "{boardTitle} Panel",
        "anchor": "mt",
        "voffset": "2.5mm",
        "hjustify": "center"
    },
    "post": {
        "millradius": "1mm",
        "origin": "bl",
        "script": "tools/kikit-post.py"
    }
}
